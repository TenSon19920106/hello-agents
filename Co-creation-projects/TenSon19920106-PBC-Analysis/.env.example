# HelloAgents LLM
LLM_MODEL_ID=Qwen/Qwen2.5-72B-Instruct
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://api-inference.modelscope.cn/v1/
LLM_TIMEOUT=120

# 智谱 OpenAPI（OpenAI 兼容）示例：model 须为开放平台「模型编码」，勿填 GLM-5.1 等无效名
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
# LLM_MODEL_ID=glm-4-flash
# 其它常见编码以控制台为准，例如：glm-4-flash-250414、glm-4.5-flash 等

# 企业绩效 / PBC 流程 HTTP 接口（按你司网关实际路径修改）
# 未配置或留空时，Notebook 内提交步骤会以「干跑」模式只打印请求体，不发起外呼
PBC_API_TOKEN=
PBC_PLANNING_URL=
PBC_FEEDBACK_URL=
# 可选：调用绩效接口超时（秒）
PBC_API_TIMEOUT=60
# 可选：HTTPS 证书校验（测试环境若为自签证书可设为 false；生产建议 true）
PBC_VERIFY_SSL=true

# khnf 年份编码基准（默认 2022：则 2022->0, 2023->1, 2024->2, 2025->3...）
KHNF_BASE_YEAR=2022

# 可选：默认考核周期，可被用户输入覆盖
PBC_DEFAULT_PERIOD=2026-Q1
